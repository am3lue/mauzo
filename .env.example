# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# IMGBB_API_KEY: Optional/Required for persistent cloud uploads of product images.
# Get a free API Key from https://api.imgbb.com/ and paste it in your Secrets.
# If not provided, data will fallback to local temporary disk storage (/tmp).
IMGBB_API_KEY=

# Turso DB Configuration
# Get these credentials from your Turso dashboard (turso.tech)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# CORS_ORIGINS: Comma-separated list of allowed origins for API cross-origin requests.
# Leave empty to allow same-origin requests only (default for same-domain deployment).
# Example: https://myapp.vercel.app,https://mauzo-staging.vercel.app
CORS_ORIGINS=
